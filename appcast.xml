    <!--
      To publish a new release:
      1. Build the DMG with ./build-distribution.sh
      2. Sign the DMG:
           ./Sparkle-2.x/bin/sign_update dist/Resistine-Installer.dmg
         This outputs the EdDSA signature and file length.
      3. Add a new <item> below with the version, signature, and download URL.
      4. Push this file to your GitHub Pages branch.
    -->

    <item>
      <title>Version 2026.03.11</title>
      <description><![CDATA[
        <h2>What's New</h2>
        <ul>
          <li>Wazuh endpoint protection agent integration with full lifecycle management</li>
          <li>Wazuh keys stored securely in macOS Keychain</li>
          <li>VPN-gated agent connectivity — agent activates only when VPN is connected</li>
          <li>Agent group registration through the API</li>
          <li>Agent auto-reconnects after install without requiring a restart</li>
          <li>Refreshed UI — replaced orange buttons with blue theme</li>
          <li>Improved uninstall and reinstall logic across macOS and Windows</li>
          <li>Multi-device login support via hostname in OTP verification</li>
          <li>Fixed Wazuh agent signup bug on macOS</li>
        </ul>
      ]]></description>
      <pubDate>Wed, 11 Mar 2026 00:00:00 +0000</pubDate>
      <sparkle:minimumSystemVersion>10.15</sparkle:minimumSystemVersion>
      <enclosure
        url="https://resistine.github.io/releases/mac/Resistine-Installer-2026.03.11.dmg"
        sparkle:version="2026.03.11"
        sparkle:shortVersionString="2026.03.11"
        length="42507261"
        type="application/octet-stream"
        sparkle:edSignature="Bnc2dSlv1jXW4tlFSDPIBE26E3CDunWClBXv2InZg9zzwfoVNkhgigP75fljgXPCgszRHS7lk4lRWp7zBnbgDA=="
      />
    </item>

